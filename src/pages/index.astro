---
import Layout from '@/layouts/Layout.astro';
import CardRenderer from '@/components/CardRenderer';
import { DEFAULT_CARD_DATA, encodeCardTemplatePreset, formatTokens, type CardData } from '@/lib/card';

const makeCard = (overrides: Partial<CardData>): CardData => ({
  ...DEFAULT_CARD_DATA,
  locale: 'zh',
  avatarType: 'emoji',
  avatarValue: '🤖',
  backgroundType: 'none',
  backgroundValue: '',
  qrcodeUrl: 'https://tokcard.dev',
  ...overrides,
});

const heroCard = makeCard({
  username: 'vibe.engineer',
  slogan: '发出来不是总结，是压迫感',
  totalTokens: 2_300_000_000,
  lastMonthTokens: 1_400_000_000,
  channel: 'claude',
  theme: 'brand-dark',
  platform: 'wechat',
  metaphorCategory: 'flex',
  primaryProjectName: 'TokCard',
  primaryProjectUrl: 'https://tokcard.dev',
  primaryProjectPitch: '把 token、项目和排行压成一张能传播的卡片',
  projects: [
    { id: 'hero-github', name: 'GitHub', icon: '🐙', url: 'https://github.com', displayType: 'icon+text' },
    { id: 'hero-site', name: 'Portfolio', icon: '🌐', url: 'https://tokcard.dev', displayType: 'icon+text' },
    { id: 'hero-saas', name: 'TokCard', icon: '⚡', url: 'https://tokcard.dev', displayType: 'icon+text' },
  ],
  modelBreakdown: [
    { name: 'Claude', percentage: 62, color: '#d97706' },
    { name: 'GPT', percentage: 24, color: '#10b981' },
    { name: 'Cursor', percentage: 14, color: '#6529c4' },
  ],
});

const showcaseCards: CardData[] = [
  heroCard,
  makeCard({
    username: 'token.diva',
    avatarValue: '⚡',
    slogan: '别人晒腹肌，我晒 token',
    totalTokens: 780_000_000,
    lastMonthTokens: 420_000_000,
    channel: 'gpt',
    theme: 'minimal-gray',
    platform: 'xiaohongshu',
    metaphorCategory: 'meme',
    primaryProjectName: 'LaunchKit AI',
    primaryProjectUrl: 'https://tokcard.dev',
    primaryProjectPitch: '把产品想法压成能快速上线的 AI 发布套件',
    projects: [
      { id: 'diva-app', name: 'AI App', icon: '📱', url: 'https://tokcard.dev', displayType: 'icon+text' },
      { id: 'diva-ph', name: 'PH', icon: '🚀', url: 'https://tokcard.dev', displayType: 'icon+text' },
    ],
    modelBreakdown: [
      { name: 'GPT', percentage: 54, color: '#10b981' },
      { name: 'Claude', percentage: 28, color: '#d97706' },
      { name: 'Gemini', percentage: 18, color: '#ef4444' },
    ],
  }),
  makeCard({
    username: 'prompt.pm',
    avatarValue: '🧠',
    slogan: '我会的不是技术，是使唤 AI',
    totalTokens: 96_000_000,
    lastMonthTokens: 60_000_000,
    channel: 'deepseek',
    theme: 'brand-light',
    platform: 'twitter',
    metaphorCategory: 'worker',
    primaryProjectName: 'SpecFlow',
    primaryProjectUrl: 'https://tokcard.dev',
    primaryProjectPitch: '把 PRD、评审和交付节奏都压进一条 AI 流水线',
    projects: [
      { id: 'pm-site', name: 'Website', icon: '🪪', url: 'https://tokcard.dev', displayType: 'icon+text' },
      { id: 'pm-case', name: 'Case Study', icon: '📊', url: 'https://tokcard.dev', displayType: 'icon+text' },
    ],
    modelBreakdown: [
      { name: 'DeepSeek', percentage: 48, color: '#1652f0' },
      { name: 'Claude', percentage: 32, color: '#d97706' },
      { name: 'GPT', percentage: 20, color: '#10b981' },
    ],
  }),
];

const showcaseMeta = [
  { platform: '朋友圈', note: '高压排面款' },
  { platform: '小红书', note: '有图有梗款' },
  { platform: 'X / LinkedIn', note: '专业名片款' },
];

// Pre-compute template URLs for showcase cards
const showcaseTemplateUrls = showcaseCards.map((card) => {
  const encoded = encodeCardTemplatePreset(card);
  return `/create?p=${encoded}`;
});
---

<Layout title="TokCard - 晒 Token、挂项目、冲排行" description="把你的 AI token 消耗做成一张精美名片，顺手展示项目，扫码查看卡片、排行和项目主页。" lang="zh">
  <main class="min-h-screen flex flex-col bg-[#fbfbfd] text-[#1d1d1f] overflow-x-hidden">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute left-[-8rem] top-[-6rem] h-[24rem] w-[24rem] rounded-full bg-[#0071e3]/10 blur-3xl"></div>
      <div class="absolute right-[-6rem] top-[8rem] h-[22rem] w-[22rem] rounded-full bg-[#7c3aed]/10 blur-3xl"></div>
    </div>

    <!-- Nav -->
    <nav class="px-5 sm:px-6 py-5 flex items-center justify-between max-w-6xl mx-auto w-full relative z-10 gap-3">
      <span class="text-lg sm:text-xl font-semibold tracking-tight">TokCard</span>
      <div class="flex items-center gap-2 sm:gap-3 whitespace-nowrap">
        <a href="/rank" class="text-sm font-medium text-[#64748b] hover:text-[#1d1d1f]">排行榜</a>
        <a href="#showcase" class="text-sm font-medium text-[#64748b] hover:text-[#1d1d1f]">亮点</a>
        <a href="/create?locale=en" class="text-sm font-medium text-[#64748b] hover:text-[#1d1d1f]">EN</a>
        <a href="/create" class="text-sm font-semibold px-3.5 sm:px-4 py-2 rounded-full bg-[#0071e3] text-white shadow-lg shadow-[#0071e3]/20 hover:scale-[1.02] transition-all">
          <span class="sm:hidden">生成卡片</span>
          <span class="hidden sm:inline">立即生成</span>
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="px-5 sm:px-6 pt-8 pb-16 md:pt-10 md:pb-24 max-w-6xl mx-auto w-full">
      <div class="grid gap-14 lg:grid-cols-[minmax(0,1.02fr)_470px] lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white/90 px-4 py-2 text-[11px] sm:text-xs font-semibold uppercase tracking-[0.14em] sm:tracking-[0.18em] text-[#0071e3] shadow-sm">
            <span>AI 名片</span>
            <span class="text-[#cbd5e1]">·</span>
            <span>Token / 项目 / 排名</span>
          </div>
          <h1 class="mt-6 sm:hidden text-[2.9rem] font-semibold tracking-tight leading-[0.98]">
            一张名片，
            <span class="block bg-[linear-gradient(135deg,#0071e3_0%,#7c3aed_60%,#f59e0b_100%)] bg-clip-text text-transparent">
              晒出你的 Token、
            </span>
            <span class="block bg-[linear-gradient(135deg,#0071e3_0%,#7c3aed_60%,#f59e0b_100%)] bg-clip-text text-transparent">
              项目和排名。
            </span>
          </h1>
          <h1 class="mt-6 hidden sm:block text-5xl md:text-7xl font-semibold tracking-tight leading-[1.02]">
            一张名片，<br />
            <span class="bg-[linear-gradient(135deg,#0071e3_0%,#7c3aed_60%,#f59e0b_100%)] bg-clip-text text-transparent">
              晒出你的 Token、项目和排名。
            </span>
          </h1>

          <p class="mt-6 max-w-2xl text-base sm:text-lg md:text-xl text-[#6b7280] leading-7 sm:leading-8">
            把 AI 用量、代表项目和排行榜位置压缩成一张可传播的社交名片。先让别人看到你有多能打，再让他们点进你的项目。
          </p>

          <div class="mt-6 flex flex-wrap gap-3 text-sm text-[#475569]">
            <span class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white px-4 py-2 shadow-sm"><span>🔥</span><span>先看 Token 战绩</span></span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white px-4 py-2 shadow-sm"><span>🧩</span><span>再看你做的项目</span></span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white px-4 py-2 shadow-sm"><span>🏆</span><span>最后看你排第几</span></span>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4">
            <a href="/create"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full font-semibold text-lg bg-[#0071e3] text-white shadow-[0_18px_40px_rgba(0,113,227,0.28)] hover:scale-[1.02] active:scale-[0.98] transition-all">
              立即生成我的 TokCard
            </a>
            <a href="/rank"
              class="inline-flex items-center justify-center gap-2 px-6 py-4 rounded-full font-medium text-lg bg-white border border-[#dbe4ff] text-[#1d1d1f] shadow-sm hover:border-[#0071e3] transition-all">
              先看别人怎么晒
            </a>
          </div>

          <div class="mt-6 text-sm text-[#6b7280]">无需注册 · 一张图带走战绩与项目 · 自带可传播链接与二维码</div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <div class="relative w-full max-w-[470px] pt-10 pb-8">
            <div class="absolute inset-0 rounded-[46px] bg-[radial-gradient(circle_at_top,rgba(0,113,227,0.20),transparent_55%)] blur-2xl"></div>
            <div class="hidden md:block absolute left-0 top-0 rounded-2xl border border-[#dbe4ff] bg-white/95 px-4 py-3 shadow-[0_18px_40px_rgba(15,23,42,0.10)] backdrop-blur">
              <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">第一眼</div>
              <div class="mt-1 text-sm font-semibold text-[#1d1d1f]">Token 战绩</div>
              <div class="mt-1 text-xs text-[#64748b]">大数字直接建立实力感</div>
            </div>
            <div class="hidden md:block absolute right-0 top-28 rounded-2xl border border-[#dbe4ff] bg-white/95 px-4 py-3 shadow-[0_18px_40px_rgba(15,23,42,0.10)] backdrop-blur">
              <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">第二眼</div>
              <div class="mt-1 text-sm font-semibold text-[#1d1d1f]">项目名片</div>
              <div class="mt-1 text-xs text-[#64748b]">别人知道你在做什么</div>
            </div>
            <div class="hidden md:block absolute left-4 bottom-0 rounded-2xl border border-[#dbe4ff] bg-white/95 px-4 py-3 shadow-[0_18px_40px_rgba(15,23,42,0.10)] backdrop-blur">
              <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">第三眼</div>
              <div class="mt-1 text-sm font-semibold text-[#1d1d1f]">排名证明</div>
              <div class="mt-1 text-xs text-[#64748b]">榜单位置带来社交证明</div>
            </div>
            <div class="relative mx-auto w-fit rotate-[-4deg] drop-shadow-[0_36px_80px_rgba(15,23,42,0.22)]">
              <CardRenderer data={heroCard} scale={0.8} renderId="landing-hero-card" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Showcase -->
    <section id="showcase" class="px-6 py-16 max-w-6xl mx-auto w-full border-t border-[#d2d2d7]/40">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">三步建立你的 AI 名片。</h2>
          <p class="mt-2 max-w-3xl text-[#6b7280]">每张 TokCard 都遵循同一个观看路径：先被 Token 吸引，再被项目打动，最后被排名留住。</p>
        </div>
      </div>

      <div class="mt-10 grid gap-8 lg:grid-cols-3">
        {showcaseCards.map((card, index) => (
          <article class="group">
            <div class="rounded-[32px] border border-[#dbe4ff] bg-white p-4 shadow-[0_18px_40px_rgba(15,23,42,0.08)] transition-transform duration-300 group-hover:-translate-y-1">
              <div class="mb-4 flex items-center justify-between text-xs font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">
                <span>{showcaseMeta[index].platform}</span>
                <span>{showcaseMeta[index].note}</span>
              </div>
              <div class="flex justify-center overflow-hidden rounded-[24px] bg-[#f8fafc] py-4">
                <CardRenderer data={card} scale={0.4} renderId={`landing-showcase-${index}`} />
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between gap-4 text-sm">
              <div>
                <div class="font-semibold text-[#1d1d1f]">@{card.username}</div>
                <div class="mt-1 text-[#6b7280]">{formatTokens(card.totalTokens, card.locale)} · {card.primaryProjectName}</div>
              </div>
              <a href={showcaseTemplateUrls[index]}
                class="rounded-full bg-[#0071e3] px-4 py-2 text-xs font-semibold text-white shadow-sm hover:opacity-95 transition-all">
                用这个方向
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Core value -->
    <section class="px-6 py-12 max-w-6xl mx-auto w-full">
      <div class="grid gap-5 lg:grid-cols-3">
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-2xl">🔥</div>
          <div class="mt-3 text-xl font-semibold text-[#1d1d1f]">先建立战绩感</div>
          <p class="mt-2 text-sm text-[#6b7280] leading-relaxed">卡片最先展示 Token 数字，让别人一眼感知你的 AI 强度和使用规模。</p>
        </div>
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-2xl">🧩</div>
          <div class="mt-3 text-xl font-semibold text-[#1d1d1f]">再带出项目感</div>
          <p class="mt-2 text-sm text-[#6b7280] leading-relaxed">把主项目和一句话介绍挂上名片，别人不只看到数据，也能点进你的作品。</p>
        </div>
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-2xl">🏆</div>
          <div class="mt-3 text-xl font-semibold text-[#1d1d1f]">最后提供证明感</div>
          <p class="mt-2 text-sm text-[#6b7280] leading-relaxed">排行榜让这张卡不只是展示工具，而是一个能比较、能发现别人项目的社交场域。</p>
        </div>
      </div>
      <div class="mt-8 rounded-[32px] border border-[#dbe4ff] bg-[linear-gradient(135deg,#ffffff_0%,#f8fbff_100%)] p-6 shadow-sm">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">TokCard 的传播路径</div>
            <div class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]">一张图先建立实力，再把流量带去你的项目。</div>
            <p class="mt-3 max-w-2xl text-sm leading-7 text-[#6b7280]">TokCard 最有价值的不是把数据做成图，而是把 Token、项目和排名压成一个别人愿意点开的入口。</p>
          </div>
          <div class="text-sm text-[#64748b]">这一步完成后，你会拿到一张可传播的 TokCard 和可直接带出去的项目入口。</div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-8 text-[13px] max-w-6xl mx-auto w-full text-[#86868b] border-t border-[#d2d2d7]/30">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <p>TokCard — 你的 AI 用量，值得一张名片</p>
        <p>Token 炫耀 · 项目展示 · 排名发现 · 一张图完成传播</p>
      </div>
    </footer>
  </main>
</Layout>
