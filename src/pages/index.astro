---
import Layout from '@/layouts/Layout.astro';
import CardRenderer from '@/components/CardRenderer';
import { DEFAULT_CARD_DATA, type CardData } from '@/lib/card';

const makeCard = (overrides: Partial<CardData>): CardData => ({
  ...DEFAULT_CARD_DATA,
  locale: 'zh',
  avatarType: 'emoji',
  avatarValue: '🤖',
  backgroundType: 'none',
  backgroundValue: '',
  qrcodeUrl: '',
  ...overrides,
});

const heroCard = makeCard({
  username: 'vibe.engineer',
  slogan: '发出来不是总结，是压迫感',
  totalTokens: 2_300_000_000,
  channel: 'claude',
  theme: 'brand-dark',
  platform: 'wechat',
  metaphorCategory: 'flex',
  modelBreakdown: [
    { name: 'Claude', percentage: 62, color: '#d97706' },
    { name: 'GPT', percentage: 24, color: '#10b981' },
    { name: 'Cursor', percentage: 14, color: '#6529c4' },
  ],
});

const showcaseCards: CardData[] = [
  heroCard,
  makeCard({
    username: 'token.diva',
    avatarValue: '⚡',
    slogan: '别人晒腹肌，我晒 token',
    totalTokens: 780_000_000,
    channel: 'gpt',
    theme: 'gradient-dream',
    platform: 'xiaohongshu',
    metaphorCategory: 'meme',
    modelBreakdown: [
      { name: 'GPT', percentage: 54, color: '#10b981' },
      { name: 'Claude', percentage: 28, color: '#d97706' },
      { name: 'Gemini', percentage: 18, color: '#ef4444' },
    ],
  }),
  makeCard({
    username: 'prompt.pm',
    avatarValue: '🧠',
    slogan: '我会的不是技术，是使唤 AI',
    totalTokens: 96_000_000,
    channel: 'deepseek',
    theme: 'brand-light',
    platform: 'twitter',
    metaphorCategory: 'worker',
    modelBreakdown: [
      { name: 'DeepSeek', percentage: 48, color: '#1652f0' },
      { name: 'Claude', percentage: 32, color: '#d97706' },
      { name: 'GPT', percentage: 20, color: '#10b981' },
    ],
  }),
];

const showcaseMeta = [
  { platform: '朋友圈', note: '高压排面款' },
  { platform: '小红书', note: '有图有梗款' },
  { platform: 'X / LinkedIn', note: '干净有态度' },
];
---

<Layout title="TokCard - AI 战绩晒图生成器" description="生成适合朋友圈、小红书、X 的 AI token 战绩卡，做一张让人想转发的晒图。">
  <main class="min-h-screen flex flex-col bg-[#fbfbfd] text-[#1d1d1f] overflow-x-hidden">
    <nav class="px-6 py-5 flex items-center justify-between max-w-6xl mx-auto w-full relative z-10">
      <span class="text-xl font-semibold tracking-tight">TokCard</span>
      <a
        href="/create"
        class="text-sm font-medium px-4 py-2 rounded-full transition-all duration-300"
        style="color: #0071e3; background: rgba(0, 113, 227, 0.08);"
        onmouseover="this.style.background='rgba(0, 113, 227, 0.12)'"
        onmouseout="this.style.background='rgba(0, 113, 227, 0.08)'"
      >
        立即生成
      </a>
    </nav>

    <section class="px-6 pt-8 pb-16 md:pt-12 md:pb-20 max-w-6xl mx-auto w-full">
      <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_380px] lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-[#d2d2d7] bg-white px-4 py-2 text-xs font-medium text-[#6b7280] shadow-sm">
            <span>适合朋友圈 / 小红书 / X</span>
            <span class="text-[#d1d5db]">·</span>
            <span>AI 战绩晒图路线</span>
          </div>

          <h1 class="mt-6 text-5xl md:text-7xl font-semibold tracking-tight leading-[1.05]">
            本月你用 AI 烧了多少？<br />
            <span class="text-[#0071e3]">做成一张能晒的战绩卡。</span>
          </h1>

          <p class="mt-6 text-lg md:text-xl leading-relaxed max-w-3xl text-[#6b7280]">
            一键生成你的 AI token 晒图，配上爆款签名、夸张比喻、二维码和平台比例，
            直接发朋友圈、小红书、X，让别人看完也想做一张。
          </p>

          <div class="mt-10 flex flex-col sm:flex-row items-center gap-4">
            <a
              href="/create"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full font-medium text-lg transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] bg-[#0071e3] text-white shadow-lg shadow-[#0071e3]/20"
            >
              立即生成我的 AI 战绩
            </a>
            <div class="text-sm text-[#6b7280]">无需注册 · 本地编辑 · 直接导出 PNG</div>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-[#6b7280]">
            <div class="rounded-full bg-white border border-[#dbe4ff] px-4 py-2 shadow-sm">200+ vibe coders 已晒图</div>
            <div class="rounded-full bg-white border border-[#dbe4ff] px-4 py-2 shadow-sm">最近 7 天最常发：朋友圈 / 小红书</div>
          </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute inset-0 bg-[#0071e3]/10 blur-3xl rounded-full scale-90"></div>
            <div class="relative rotate-[-6deg] drop-shadow-[0_30px_60px_rgba(15,23,42,0.18)]">
              <CardRenderer data={heroCard} scale={0.66} renderId="landing-hero-card" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-16 max-w-6xl mx-auto w-full border-t border-[#d2d2d7]/40">
      <div class="grid gap-5 md:grid-cols-3">
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-xs uppercase tracking-[0.18em] text-[#94a3b8]">不是报表，是内容</div>
          <div class="mt-3 text-2xl font-semibold">别人一眼看懂你有多重度。</div>
          <p class="mt-3 text-sm leading-6 text-[#6b7280]">
            不是后台截图，也不是枯燥统计图，而是一张带情绪、带态度、能被转发的战绩卡。
          </p>
        </div>
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-xs uppercase tracking-[0.18em] text-[#94a3b8]">不是描述，是金句</div>
          <div class="mt-3 text-2xl font-semibold">签名、比喻、底部水印都能出梗。</div>
          <p class="mt-3 text-sm leading-6 text-[#6b7280]">
            发出去不是“我用了很多 token”，而是“别人看完也想立刻做一张”的记忆点。
          </p>
        </div>
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-xs uppercase tracking-[0.18em] text-[#94a3b8]">不是适配，是开箱即发</div>
          <div class="mt-3 text-2xl font-semibold">平台比例 + 导出文案一次给齐。</div>
          <p class="mt-3 text-sm leading-6 text-[#6b7280]">
            选好朋友圈、小红书或 X，导出后直接带走一段可复制的发帖文案。
          </p>
        </div>
      </div>
    </section>

    <section class="px-6 py-16 max-w-6xl mx-auto w-full border-t border-[#d2d2d7]/40">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <div class="text-sm font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">Real showcase</div>
          <h2 class="mt-3 text-3xl md:text-4xl font-semibold tracking-tight">你发出去的，不该像工具截图。</h2>
        </div>
        <a href="/create" class="text-sm font-medium text-[#0071e3]">去做我的版本</a>
      </div>

      <div class="mt-10 grid gap-8 lg:grid-cols-3">
        {showcaseCards.map((card, index) => (
          <article class="group">
            <div class="rounded-[32px] border border-[#dbe4ff] bg-white p-4 shadow-[0_18px_40px_rgba(15,23,42,0.08)] transition-transform duration-300 group-hover:-translate-y-1">
              <div class="flex justify-center overflow-hidden rounded-[24px] bg-[#f8fafc] py-4">
                <CardRenderer data={card} scale={0.4} renderId={`landing-showcase-${index}`} />
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between gap-4 text-sm">
              <div>
                <div class="font-semibold text-[#1d1d1f]">@{card.username}</div>
                <div class="mt-1 text-[#6b7280]">{showcaseMeta[index].platform} · {showcaseMeta[index].note}</div>
              </div>
              <div class="rounded-full bg-[#f8fafc] px-3 py-1.5 text-xs font-medium text-[#64748b] border border-[#e2e8f0]">
                {card.totalTokens >= 1_000_000_000 ? `${(card.totalTokens / 1_000_000_000).toFixed(1)}B` : `${Math.round(card.totalTokens / 1_000_000)}M`} tokens
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="px-6 py-16 max-w-6xl mx-auto w-full border-t border-[#d2d2d7]/40">
      <div class="grid gap-5 md:grid-cols-4">
        <div class="rounded-[24px] bg-white border border-[#dbe4ff] p-5 shadow-sm">
          <div class="text-3xl font-semibold tracking-tight">200+</div>
          <div class="mt-2 text-sm text-[#6b7280]">正在晒 AI 战绩的人</div>
        </div>
        <div class="rounded-[24px] bg-white border border-[#dbe4ff] p-5 shadow-sm">
          <div class="text-3xl font-semibold tracking-tight">10</div>
          <div class="mt-2 text-sm text-[#6b7280]">可切换主题风格</div>
        </div>
        <div class="rounded-[24px] bg-white border border-[#dbe4ff] p-5 shadow-sm">
          <div class="text-3xl font-semibold tracking-tight">6</div>
          <div class="mt-2 text-sm text-[#6b7280]">社交平台比例</div>
        </div>
        <div class="rounded-[24px] bg-white border border-[#dbe4ff] p-5 shadow-sm">
          <div class="text-3xl font-semibold tracking-tight">Copy</div>
          <div class="mt-2 text-sm text-[#6b7280]">导出后附赠分享文案</div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20 max-w-5xl mx-auto w-full border-t border-[#d2d2d7]/40 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">把你的 AI 用量，做成别人会收藏的那种图。</h2>
      <p class="mt-5 text-lg text-[#6b7280] max-w-2xl mx-auto leading-relaxed">
        不是为了记账，是为了让你的 AI 工作流看起来更猛、更有趣、更值得发出来。
      </p>
      <a
        href="/create"
        class="mt-8 inline-flex items-center justify-center px-8 py-4 rounded-full font-medium text-lg transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] bg-[#0071e3] text-white shadow-lg shadow-[#0071e3]/20"
      >
        去做我的晒图
      </a>
    </section>

    <footer class="px-6 py-8 text-[13px] max-w-6xl mx-auto w-full text-[#86868b] border-t border-[#d2d2d7]/30">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <p>TokCard.dev — AI 战绩晒图生成器</p>
        <p>Open source. No tracking. Your data stays local.</p>
      </div>
    </footer>
  </main>
</Layout>
