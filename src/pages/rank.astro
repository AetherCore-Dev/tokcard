---
import Layout from '@/layouts/Layout.astro';
import Leaderboard from '@/components/Leaderboard';
---

<Layout
  title="排行榜 - TokCard AI Token 消耗排名"
  description="看看谁消耗了最多的 AI token？TokCard 排行榜展示最硬核的 AI 开发者和他们的项目。"
  lang="zh"
>
  <main class="min-h-screen flex flex-col bg-[#fbfbfd] text-[#1d1d1f]">
    <nav class="px-6 py-5 flex items-center justify-between max-w-6xl mx-auto w-full">
      <a href="/" class="text-xl font-semibold tracking-tight">TokCard</a>
      <div class="flex items-center gap-3">
        <a href="/rank" class="text-sm font-medium text-[#0071e3]">排行榜</a>
        <a
          href="/create"
          class="text-sm font-semibold px-4 py-2 rounded-full bg-[#0071e3] text-white shadow-lg shadow-[#0071e3]/20 hover:scale-[1.02] transition-all"
        >
          生成卡片
        </a>
      </div>
    </nav>

    <Leaderboard client:load />
  </main>
</Layout>
