---
import Layout from '@/layouts/Layout.astro';
import CardRenderer from '@/components/CardRenderer';
import { DEFAULT_CARD_DATA, encodeCardTemplatePreset, formatTokens, getTokenWindowLabel, type CardData } from '@/lib/card';

const locale = 'en';

const t = {
  title: 'TokCard - Turn tokens into a shareable card',
  description: 'Turn your AI token usage into a polished social card that also showcases your project, ranking, and share link.',
  navRank: 'Leaderboard',
  navShowcase: 'Examples',
  navLocale: '中文',
  navLocaleHref: '/',
  cta: 'Create now',
  ctaShort: 'Create',
  heroBadge: 'AI CARD',
  heroBadgeSub: 'TOKEN / PROJECT / RANK',
  heroLine1: 'Turn your',
  heroHighlight: 'tokens, project, and rank',
  heroLine3: 'into one card.',
  heroSub: 'Show token strength first, then send attention to your project.',
  feature1: 'Day / Week / Month',
  feature2: 'Project link',
  feature3: 'Leaderboard',
  heroSecondaryCta: 'View leaderboard',
  heroFooter: 'No signup · Export and share instantly · Built-in link and QR',
  showcaseTitle: 'Featured examples',
  showcaseSub: 'Pick a direction, then swap in your own tokens and project.',
  useDirection: 'Use this style',
  value1Title: 'Lead with tokens',
  value1Body: 'A big number creates instant signal.',
  value2Title: 'Then show the project',
  value2Body: 'Let people click straight into what you are building.',
  value3Title: 'Then show the rank',
  value3Body: 'Add screenshot proof and enter the board.',
  flowEyebrow: 'TokCard distribution loop',
  flowTitle: 'One card to prove strength first, then route traffic to your project.',
  flowBody: 'Tokens, project, and rank travel together.',
  flowCta: 'Start building',
  footerLeft: 'TokCard — turn tokens, project, and rank into one card',
  footerRight: 'Export and share instantly',
  showcaseMeta: [
    { platform: 'WeChat', note: 'High-signal flex' },
    { platform: 'Xiaohongshu', note: 'Visual + viral' },
    { platform: 'X / LinkedIn', note: 'Professional card' },
  ],
};

const makeCard = (overrides: Partial<CardData>): CardData => ({
  ...DEFAULT_CARD_DATA,
  locale,
  avatarType: 'emoji',
  avatarValue: '🤖',
  backgroundType: 'none',
  backgroundValue: '',
  qrcodeUrl: 'https://tokcard.dev',
  ...overrides,
});

const heroCard = makeCard({
  username: 'vibe.engineer',
  slogan: "It is not a recap. It's pressure.",
  totalTokens: 2_300_000_000,
  tokenWindow: 'month',
  lastMonthTokens: 1_400_000_000,
  channel: 'claude',
  theme: 'velvet-night',
  platform: 'wechat',
  metaphorCategory: 'flex',
  primaryProjectName: 'TokCard',
  primaryProjectUrl: 'https://tokcard.dev',
  primaryProjectPitch: 'Turn tokens, projects, and ranking into one shareable card.',
  projects: [
    { id: 'hero-github', name: 'GitHub', icon: '🐙', url: 'https://github.com', displayType: 'icon+text' },
    { id: 'hero-site', name: 'Portfolio', icon: '🌐', url: 'https://tokcard.dev', displayType: 'icon+text' },
    { id: 'hero-saas', name: 'TokCard', icon: '⚡', url: 'https://tokcard.dev', displayType: 'icon+text' },
  ],
  modelBreakdown: [
    { name: 'Claude', percentage: 62, color: '#d97706' },
    { name: 'GPT', percentage: 24, color: '#10b981' },
    { name: 'Cursor', percentage: 14, color: '#6529c4' },
  ],
});

const showcaseCards: CardData[] = [
  heroCard,
  makeCard({
    username: 'token.diva',
    avatarValue: '⚡',
    slogan: 'Others flex abs. I flex tokens.',
    totalTokens: 780_000_000,
    tokenWindow: 'week',
    lastMonthTokens: 420_000_000,
    channel: 'gpt',
    theme: 'sunset-paper',
    platform: 'xiaohongshu',
    metaphorCategory: 'meme',
    primaryProjectName: 'LaunchKit AI',
    primaryProjectUrl: 'https://tokcard.dev',
    primaryProjectPitch: 'Compress product ideas into an AI launch kit you can ship fast.',
    projects: [
      { id: 'diva-app', name: 'AI App', icon: '📱', url: 'https://tokcard.dev', displayType: 'icon+text' },
      { id: 'diva-ph', name: 'PH', icon: '🚀', url: 'https://tokcard.dev', displayType: 'icon+text' },
    ],
    modelBreakdown: [
      { name: 'GPT', percentage: 54, color: '#10b981' },
      { name: 'Claude', percentage: 28, color: '#d97706' },
      { name: 'Gemini', percentage: 18, color: '#ef4444' },
    ],
  }),
  makeCard({
    username: 'prompt.pm',
    avatarValue: '🧠',
    slogan: 'My edge is not code. It is directing AI.',
    totalTokens: 96_000_000,
    tokenWindow: 'day',
    lastMonthTokens: 60_000_000,
    channel: 'deepseek',
    theme: 'aurora-mint',
    platform: 'twitter',
    metaphorCategory: 'worker',
    primaryProjectName: 'SpecFlow',
    primaryProjectUrl: 'https://tokcard.dev',
    primaryProjectPitch: 'Push PRD, review, and delivery into one AI production line.',
    projects: [
      { id: 'pm-site', name: 'Website', icon: '🪪', url: 'https://tokcard.dev', displayType: 'icon+text' },
      { id: 'pm-case', name: 'Case Study', icon: '📊', url: 'https://tokcard.dev', displayType: 'icon+text' },
    ],
    modelBreakdown: [
      { name: 'DeepSeek', percentage: 48, color: '#1652f0' },
      { name: 'Claude', percentage: 32, color: '#d97706' },
      { name: 'GPT', percentage: 20, color: '#10b981' },
    ],
  }),
];

const showcaseTemplateUrls = showcaseCards.map((card) => {
  const encoded = encodeCardTemplatePreset(card);
  return `/en/create?p=${encoded}`;
});
---

<Layout title={t.title} description={t.description} lang={locale}>
  <main class="min-h-screen flex flex-col bg-[#fbfbfd] text-[#1d1d1f] overflow-x-hidden">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute left-[-8rem] top-[-6rem] h-[24rem] w-[24rem] rounded-full bg-[#0071e3]/10 blur-3xl"></div>
      <div class="absolute right-[-6rem] top-[8rem] h-[22rem] w-[22rem] rounded-full bg-[#7c3aed]/10 blur-3xl"></div>
    </div>

    <nav class="px-5 sm:px-6 py-5 flex items-center justify-between max-w-6xl mx-auto w-full relative z-10 gap-3">
      <span class="text-lg sm:text-xl font-semibold tracking-tight">TokCard</span>
      <div class="flex items-center gap-2 sm:gap-3 whitespace-nowrap">
        <a href="/en/rank" class="text-sm font-medium text-[#64748b] hover:text-[#1d1d1f]">{t.navRank}</a>
        <a href="#showcase" class="text-sm font-medium text-[#64748b] hover:text-[#1d1d1f]">{t.navShowcase}</a>
        <a href={t.navLocaleHref} class="text-sm font-medium text-[#64748b] hover:text-[#1d1d1f]">{t.navLocale}</a>
        <a href="/en/create" class="text-sm font-semibold px-3.5 sm:px-4 py-2 rounded-full bg-[#0071e3] text-white shadow-lg shadow-[#0071e3]/20 hover:scale-[1.02] transition-all">
          <span class="sm:hidden">{t.ctaShort}</span>
          <span class="hidden sm:inline">{t.cta}</span>
        </a>
      </div>
    </nav>

    <section class="px-5 sm:px-6 pt-8 pb-16 md:pt-10 md:pb-24 max-w-6xl mx-auto w-full">
      <div class="grid gap-14 lg:grid-cols-[minmax(0,1.02fr)_470px] lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white/90 px-4 py-2 text-[11px] sm:text-xs font-semibold uppercase tracking-[0.14em] sm:tracking-[0.18em] text-[#0071e3] shadow-sm">
            <span>{t.heroBadge}</span>
            <span class="text-[#cbd5e1]">·</span>
            <span>{t.heroBadgeSub}</span>
          </div>
          <h1 class="mt-6 sm:hidden text-[2.9rem] font-semibold tracking-tight leading-[0.98]">
            {t.heroLine1}
            <span class="block bg-[linear-gradient(135deg,#0071e3_0%,#7c3aed_60%,#f59e0b_100%)] bg-clip-text text-transparent">
              {t.heroHighlight}
            </span>
            <span class="block">{t.heroLine3}</span>
          </h1>
          <h1 class="mt-6 hidden sm:block text-5xl md:text-7xl font-semibold tracking-tight leading-[1.02]">
            {t.heroLine1}<br />
            <span class="bg-[linear-gradient(135deg,#0071e3_0%,#7c3aed_60%,#f59e0b_100%)] bg-clip-text text-transparent">
              {t.heroHighlight}
            </span><br />
            {t.heroLine3}
          </h1>

          <p class="mt-6 max-w-xl text-base sm:text-lg md:text-xl text-[#6b7280] leading-7 sm:leading-8">
            {t.heroSub}
          </p>

          <div class="mt-6 flex flex-wrap gap-3 text-sm text-[#475569]">
            <span class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white px-4 py-2 shadow-sm"><span>{t.feature1}</span></span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white px-4 py-2 shadow-sm"><span>{t.feature2}</span></span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[#dbe4ff] bg-white px-4 py-2 shadow-sm"><span>{t.feature3}</span></span>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4">
            <a href="/en/create"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full font-semibold text-lg bg-[#0071e3] text-white shadow-[0_18px_40px_rgba(0,113,227,0.28)] hover:scale-[1.02] active:scale-[0.98] transition-all">
              {t.cta}
            </a>
            <a href="/en/rank"
              class="inline-flex items-center justify-center gap-2 px-6 py-4 rounded-full font-medium text-lg bg-white border border-[#dbe4ff] text-[#1d1d1f] shadow-sm hover:border-[#0071e3] transition-all">
              {t.heroSecondaryCta}
            </a>
          </div>

          <div class="mt-6 text-sm text-[#6b7280]">{t.heroFooter}</div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <div class="relative w-full max-w-[470px] pt-10 pb-8">
            <div class="absolute inset-0 rounded-[46px] bg-[radial-gradient(circle_at_top,rgba(0,113,227,0.20),transparent_55%)] blur-2xl"></div>
            <div class="relative mx-auto w-fit rotate-[-4deg] drop-shadow-[0_36px_80px_rgba(15,23,42,0.22)]">
              <CardRenderer data={heroCard} scale={0.8} renderId="landing-hero-card-en" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="showcase" class="px-6 py-16 max-w-6xl mx-auto w-full border-t border-[#d2d2d7]/40">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">{t.showcaseTitle}</h2>
          <p class="mt-2 max-w-2xl text-[#6b7280]">{t.showcaseSub}</p>
        </div>
      </div>

      <div class="mt-10 grid gap-8 lg:grid-cols-3">
        {showcaseCards.map((card, index) => (
          <article class="group">
            <div class="rounded-[32px] border border-[#dbe4ff] bg-white p-4 shadow-[0_18px_40px_rgba(15,23,42,0.08)] transition-transform duration-300 group-hover:-translate-y-1">
              <div class="mb-4 flex items-center justify-between text-xs font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">
                <span>{t.showcaseMeta[index].platform}</span>
                <span>{t.showcaseMeta[index].note}</span>
              </div>
              <div class="flex justify-center overflow-hidden rounded-[24px] bg-[#f8fafc] py-4">
                <CardRenderer data={card} scale={0.4} renderId={`landing-showcase-en-${index}`} />
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between gap-4 text-sm">
              <div>
                <div class="font-semibold text-[#1d1d1f]">@{card.username}</div>
                <div class="mt-1 text-[#6b7280]">{getTokenWindowLabel(card.tokenWindow, card.locale)} · {formatTokens(card.totalTokens, card.locale)} · {card.primaryProjectName}</div>
              </div>
              <a href={showcaseTemplateUrls[index]}
                class="rounded-full bg-[#0071e3] px-4 py-2 text-xs font-semibold text-white shadow-sm hover:opacity-95 transition-all">
                {t.useDirection}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="px-6 py-12 max-w-6xl mx-auto w-full">
      <div class="grid gap-5 lg:grid-cols-3">
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-2xl">🔥</div>
          <div class="mt-3 text-xl font-semibold text-[#1d1d1f]">{t.value1Title}</div>
          <p class="mt-2 text-sm text-[#6b7280] leading-relaxed">{t.value1Body}</p>
        </div>
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-2xl">🧩</div>
          <div class="mt-3 text-xl font-semibold text-[#1d1d1f]">{t.value2Title}</div>
          <p class="mt-2 text-sm text-[#6b7280] leading-relaxed">{t.value2Body}</p>
        </div>
        <div class="rounded-[28px] border border-[#dbe4ff] bg-white p-6 shadow-sm">
          <div class="text-2xl">🏆</div>
          <div class="mt-3 text-xl font-semibold text-[#1d1d1f]">{t.value3Title}</div>
          <p class="mt-2 text-sm text-[#6b7280] leading-relaxed">{t.value3Body}</p>
        </div>
      </div>
      <div class="mt-8 rounded-[32px] border border-[#dbe4ff] bg-[linear-gradient(135deg,#ffffff_0%,#f8fbff_100%)] p-6 shadow-sm">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#94a3b8]">{t.flowEyebrow}</div>
            <div class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]">{t.flowTitle}</div>
            <p class="mt-3 max-w-xl text-sm leading-7 text-[#6b7280]">{t.flowBody}</p>
          </div>
          <a href="/en/create" class="inline-flex items-center justify-center rounded-full bg-[#0071e3] px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(0,113,227,0.22)]">{t.flowCta}</a>
        </div>
      </div>
    </section>

    <footer class="px-6 py-8 text-[13px] max-w-6xl mx-auto w-full text-[#86868b] border-t border-[#d2d2d7]/30">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <p>{t.footerLeft}</p>
        <p>{t.footerRight}</p>
      </div>
    </footer>
  </main>
</Layout>
